#include<iostream>
using namespace std;

int main() {

	const int n = 5;
	int arr[n];
	int value;
	int foundnot = -1;   

	cout << "Enter " << n << " number for arrays: ";
	for (int i = 0; i < n; i++) {
		cin >> arr[i];
	}

	cout << "Enter number to find: ";
	cin >> value;

	for (int i = 0; i < n; i++) {
		if (arr[i] == value) {
			foundnot = i;   
			break;          
		}
	}

	cout << foundnot;   

	return 0;
}
